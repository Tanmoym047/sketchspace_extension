{
  "manifest_version": 3,
  "name": "SketchSpace Clipper",
  "version": "1.0",
  "permissions": ["activeTab", "tabs"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://sketchspace-46391.web.app/*", "http://localhost:5173/*"],
      "js": ["content.js"]
    }
  ]
}